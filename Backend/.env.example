# ── FlowMind Backend environment ────────────────────────────────
ENVIRONMENT=development
DEBUG=true

# API
API_V1_PREFIX=/api/v1
PROJECT_NAME=FlowMind
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8081","http://localhost:19006"]

# Security — generate with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-long-random-secret-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
ALGORITHM=HS256

# PostgreSQL
POSTGRES_USER=flowmind
POSTGRES_PASSWORD=flowmind
POSTGRES_DB=flowmind
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=300

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# MLflow
MLFLOW_TRACKING_URI=file:./mlruns
ML_MODEL_DIR=./ml_artifacts

# Rate limiting
RATE_LIMIT_DEFAULT=120/minute
