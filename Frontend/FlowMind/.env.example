# FlowMind Frontend environment.
#
# Override the backend URL by editing app.json -> expo.extra.apiBaseUrl,
# OR by setting EXPO_PUBLIC_API_BASE_URL and reading it in client.ts.
#
# Defaults to http://localhost:8000 (the FastAPI dev server).
#
# When testing on a real device with Expo Go, localhost points to the
# phone, not your laptop. Use your machine's LAN IP:
#   EXPO_PUBLIC_API_BASE_URL=http://192.168.1.42:8000
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000
