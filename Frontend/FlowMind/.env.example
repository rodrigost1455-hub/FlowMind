# FlowMind web client — environment.
#
# Copy to `.env` (gitignored) and edit as needed. Anything prefixed with
# VITE_ is exposed to the bundle via `import.meta.env`.

# Backend base URL (no trailing slash, no /api/v1 suffix — that's appended).
# Defaults to the production Render deployment if unset.
VITE_API_BASE_URL=http://localhost:8000
