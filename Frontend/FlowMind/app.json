{
  "expo": {
    "name": "FlowMind",
    "slug": "flowmind",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "flowmind",
    "splash": {
      "backgroundColor": "#0B0F1A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.flowmind.mobile"
    },
    "android": {
      "package": "app.flowmind.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#0B0F1A"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "apiBaseUrl": "http://localhost:8000"
    }
  }
}
